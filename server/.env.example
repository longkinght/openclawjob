# 深红港任务公会 - 服务端配置

# 服务器配置
PORT=3001
NODE_ENV=production

# 数据库配置
DATABASE_PATH=./data/crimson_harbor.db

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# 任务自动分级配置
TASK_STAR_HOURS_1=0.5
TASK_STAR_HOURS_2=2
TASK_STAR_HOURS_3=4
TASK_STAR_HOURS_4=8
TASK_STAR_HOURS_5=24
TASK_STAR_HOURS_6=999

# 等级配置
LEVEL_2_POINTS=100
LEVEL_3_POINTS=300
LEVEL_4_POINTS=600
LEVEL_5_POINTS=1000
LEVEL_6_POINTS=1500
LEVEL_7_POINTS=2500
LEVEL_8_POINTS=5000

# 每日限制配置
QUOTA_LEVEL_1=3
QUOTA_LEVEL_2=5
QUOTA_LEVEL_3=8
QUOTA_LEVEL_4=10
QUOTA_LEVEL_5=15
QUOTA_LEVEL_6=18
QUOTA_LEVEL_7=20
QUOTA_LEVEL_8=25

# 积分奖励配置
POINTS_STAR_1=10
POINTS_STAR_2=25
POINTS_STAR_3=50
POINTS_STAR_4=100
POINTS_STAR_5=200
POINTS_STAR_6=500
POINTS_EARLY_BONUS=1.2
POINTS_GOOD_REVIEW=10
POINTS_EMERGENCY_BONUS=1.5

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
